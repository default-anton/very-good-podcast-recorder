#!/usr/bin/env bash
set -euo pipefail

go vet ./...

frontend_roots=()
for path in web e2e; do
  if [[ -d "$path" ]]; then
    frontend_roots+=("$path")
  fi
done

frontend_files=()
if [[ ${#frontend_roots[@]} -gt 0 ]]; then
  mapfile -t frontend_files < <(fd -t f -e ts -e tsx . "${frontend_roots[@]}")
fi
frontend_files+=(playwright.config.ts vitest.config.ts)

if [[ ${#frontend_files[@]} -gt 0 ]]; then
  pnpm exec oxlint "${frontend_files[@]}"
fi

{
  "name": "very-good-podcast-recorder",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "format": "./scripts/format",
    "format:check": "./scripts/format --check",
    "lint": "./scripts/lint",
    "typecheck": "./scripts/typecheck",
    "test": "./scripts/test",
    "test:unit": "go test ./... && pnpm exec vitest run",
    "test:e2e": "pnpm exec playwright test --pass-with-no-tests",
    "check": "./scripts/check",
    "audit": "./scripts/audit",
    "hooks:install": "pnpm exec prek install",
    "hooks:run": "pnpm exec prek run --all-files"
  },
  "devDependencies": {
    "@j178/prek": "0.3.6",
    "@playwright/test": "1.58.2",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260322.1",
    "@vitejs/plugin-react": "^6.0.1",
    "oxfmt": "0.41.0",
    "oxlint": "1.56.0",
    "tailwindcss": "^4.2.2",
    "vite": "8.0.1",
    "vitest": "4.1.0"
  },
  "dependencies": {
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@tanstack/react-query": "^5.95.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.2",
    "tailwind-merge": "^3.5.0"
  }
}
